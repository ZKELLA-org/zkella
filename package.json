{
  "name": "zkella-protocol",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test":        "jest --testPathPattern='tests/unit'",
    "test:e2e":    "jest --testPathPattern='tests/e2e' --testTimeout=90000",
    "test:all":    "jest",
    "build:sdk":   "cd sdk && npm run build",
    "install:all": "npm install && cd sdk && npm install"
  },
  "devDependencies": {
    "@types/jest":  "^29.5.0",
    "@types/node":  "^20.0.0",
    "jest":         "^29.7.0",
    "ts-jest":      "^29.1.0",
    "typescript":   "^5.4.0"
  },
  "dependencies": {
    "@noble/ciphers": "^0.5.0",
    "@noble/hashes":  "^1.4.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "circomlibjs":    "^0.1.7"
  },
  "jest": {
    "preset":              "ts-jest",
    "testEnvironment":     "node",
    "moduleFileExtensions": ["ts", "js"],
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    },
    "testTimeout": 60000,
    "testMatch": ["**/tests/**/*.test.ts"]
  }
}
